# Docker Compose 环境变量（可按需覆盖）

# ------------------------------
# MySQL 初始化参数
# ------------------------------
# MySQL root 管理员密码
MYSQL_ROOT_PASSWORD=root123456
# 首次启动时自动创建的业务数据库名
MYSQL_DATABASE=zongce
# 业务数据库登录账号
MYSQL_USER=zongce
# 业务数据库登录密码
MYSQL_PASSWORD=zongce123!

# ------------------------------
# 宿主机端口映射
# ------------------------------
# 宿主机端口 -> mysql:3306
MYSQL_PORT=3306
# 宿主机端口 -> backend:8082
BACKEND_PORT=8082
# 宿主机端口 -> frontend:80
FRONTEND_PORT=5173

# ------------------------------
# 安全配置
# ------------------------------
# JWT 签名密钥，长度至少 32 个字符
# 交付或生产部署前务必替换
JWT_SECRET=ReplaceThisWithARealJwtSecretAtLeast32Chars

# ------------------------------
# 系统初始化行为
# ------------------------------
# 新建账号/重置密码时使用的初始密码
APP_USER_INITIAL_PASSWORD=123456
# 是否在启动时执行初始化逻辑
APP_BOOTSTRAP_ENABLED=true
# 是否自动创建示例教师/学生账号（仅在用户表为空时生效）
APP_BOOTSTRAP_CREATE_SAMPLE_USERS=false

# 容器时区
TZ=Asia/Shanghai
